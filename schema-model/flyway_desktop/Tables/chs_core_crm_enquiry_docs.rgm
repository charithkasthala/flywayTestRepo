table "flyway_desktop"."chs_core_crm_enquiry_docs" {
  columns = (
    column "id" {
      type = bigint
      null = NOT NULL
    }
    column "enquiry_id" {
      type = bigint
      null = NOT NULL
    }
    column "file_id" {
      type = varchar(50)
    }
    column "doc_url" {
      type = varchar(500)
      null = NOT NULL
    }
    column "created_on" {
      type = datetime
    }
    column "created_by" {
      type = varchar(50)
    }
    column "modified_on" {
      type = datetime
      default = CURRENT_TIMESTAMP
    }
    column "modified_by" {
      type = varchar(100)
    }
  )
  primaryKey = {
    columns = [
      id
    ]
    name = "PRIMARY"
    objectType = primaryKey
  }
}

foreignKey "flyway_desktop"."chs_core_crm_enquiry_docs"."fk_enq_docs_enquiry" {
  columns = [
    "enquiry_id"
  ]
  referencedTable = "flyway_desktop"."chs_core_crm_enquiry"
  referencedColumns = [
    "id"
  ]
}

index "flyway_desktop"."chs_core_crm_enquiry_docs"."fk_enq_docs_enquiry" {
  columns = <
    {
      name = enquiry_id
    }

  >
  type = BTREE
}

index "flyway_desktop"."chs_core_crm_enquiry_docs"."id_UNIQUE" {
  columns = <
    {
      name = id
    }

  >
  type = BTREE
  unique = UNIQUE
}

