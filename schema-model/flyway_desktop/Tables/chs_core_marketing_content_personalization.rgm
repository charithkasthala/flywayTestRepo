  ]
  onDelete = SET NULL
}

foreignKey "flyway_desktop"."chs_core_marketing_content_personalization"."chs_core_marketing_content_personalization_ibfk_2" {
  columns = [
    "segment_id"
  ]
  referencedTable = "flyway_desktop"."chs_core_marketing_segment"
