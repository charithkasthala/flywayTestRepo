table "flyway_desktop"."chs_ecom_sales_low_selling_products" {
  columns = (
    column "id" {
      type = bigint
      null = NOT NULL
    }
    column "report_date" {
      type = date
      null = NOT NULL
    }
    column "generated_on" {
      type = datetime
    }
    column "item_title" {
      type = varchar(100)
      null = NOT NULL
    }
    column "item_slug" {
      type = varchar(50)
      null = NOT NULL
    }
    column "img_url" {
      type = varchar(500)
    }
    column "item_sku" {
      type = varchar(50)
    }
    column "value_type" {
      type = enum('REVENUE','QUANTITY')
      null = NOT NULL
    }
    column "value" {
      type = decimal(10,2)
      null = NOT NULL
    }
  )
  primaryKey = {
    columns = [
      id
    ]
    name = "PRIMARY"
    objectType = primaryKey
  }
}

