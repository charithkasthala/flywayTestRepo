    }

  >
  type = BTREE
}

index "flyway_desktop"."chs_core_marketing_loyalty_program"."idx_loyalty_type" {
  columns = <
    {
      name = program_type
    }

  >
  type = BTREE
}

index "flyway_desktop"."chs_core_marketing_loyalty_program"."program_code" {
  columns = <
    {
      name = program_code
    }

  >
  type = BTREE
  unique = UNIQUE
}

