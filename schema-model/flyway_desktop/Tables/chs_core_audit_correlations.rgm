table "flyway_desktop"."chs_core_audit_correlations" {
  columns = (
    column "id" {
      type = varchar(50)
      null = NOT NULL
      default = """-
(uuid())
"""
    }
    column "user_id" {
      type = varchar(100)
    }
    column "channel" {
      type = varchar(50)
    }
    column "client" {
      type = varchar(50)
    }
    column "token" {
      type = varchar(255)
    }
    column "logged_in_at" {
      type = datetime
    }
    column "logged_out_at" {
      type = datetime
    }
    column "duration_ms" {
      type = bigint
    }
    column "tenant_id" {
      type = varchar(50)
    }
  )
  primaryKey = {
    columns = [
      id
    ]
    name = "PRIMARY"
    objectType = primaryKey
  }
}

index "flyway_desktop"."chs_core_audit_correlations"."id_UNIQUE" {
  columns = <
    {
      name = id
    }

  >
  type = BTREE
  unique = UNIQUE
}

index "flyway_desktop"."chs_core_audit_correlations"."token_UNIQUE" {
  columns = <
    {
      name = token
    }

  >
  type = BTREE
  unique = UNIQUE
}

