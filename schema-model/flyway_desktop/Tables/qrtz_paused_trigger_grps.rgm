table "flyway_desktop"."qrtz_paused_trigger_grps" {
  columns = (
    column "SCHED_NAME" {
      type = varchar(120)
      null = NOT NULL
    }
    column "TRIGGER_GROUP" {
      type = varchar(200)
      null = NOT NULL
    }
  )
  primaryKey = {
    columns = [
      SCHED_NAME
      TRIGGER_GROUP
    ]
    name = "PRIMARY"
    objectType = primaryKey
  }
}

