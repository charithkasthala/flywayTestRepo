  ]
  onDelete = CASCADE
}

foreignKey "flyway_desktop"."chs_core_marketing_loyalty_redemption"."chs_core_marketing_loyalty_redemption_ibfk_2" {
  columns = [
    "coupon_id"
  ]
  referencedTable = "flyway_desktop"."chs_core_marketing_coupon"
  referencedColumns = [
    "id"
  ]
  onDelete = SET NULL
}

