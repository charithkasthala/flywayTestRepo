table "flyway_desktop"."warehouse_master" {
  columns = (
    column "id" {
      type = varchar(50)
      null = NOT NULL
    }
    column "type_code" {
      type = varchar(50)
    }
    column "name" {
      type = varchar(100)
      null = NOT NULL
    }
    column "code" {
      type = varchar(50)
      null = NOT NULL
    }
    column "email" {
      type = varchar(500)
    }
    column "mobile_number" {
      type = varchar(15)
    }
    column "address_id" {
      type = varchar(50)
    }
    column "region_code" {
      type = varchar(50)
    }
    column "status" {
      type = enum('ACTIVE','FULL','INACTIVE')
      default = 'ACTIVE'
    }
    column "created_on" {
      type = datetime
      default = CURRENT_TIMESTAMP
    }
    column "created_by" {
      type = varchar(50)
    }
    column "modified_on" {
      type = datetime
      default = CURRENT_TIMESTAMP
    }
    column "modified_by" {
      type = varchar(50)
    }
  )
  primaryKey = {
    columns = [
      id
    ]
    name = "PRIMARY"
    objectType = primaryKey
  }
}

index "flyway_desktop"."warehouse_master"."code" {
  columns = <
    {
      name = code
    }

  >
  type = BTREE
  unique = UNIQUE
}

