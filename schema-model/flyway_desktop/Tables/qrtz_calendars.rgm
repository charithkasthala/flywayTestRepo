table "flyway_desktop"."qrtz_calendars" {
  columns = (
    column "SCHED_NAME" {
      type = varchar(120)
      null = NOT NULL
    }
    column "CALENDAR_NAME" {
      type = varchar(200)
      null = NOT NULL
    }
    column "CALENDAR" {
      type = blob
      null = NOT NULL
    }
  )
  primaryKey = {
    columns = [
      SCHED_NAME
      CALENDAR_NAME
    ]
    name = "PRIMARY"
    objectType = primaryKey
  }
}

