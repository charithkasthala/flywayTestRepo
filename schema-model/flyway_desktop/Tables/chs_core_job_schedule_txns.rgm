table "flyway_desktop"."chs_core_job_schedule_txns" {
  columns = (
    column "txn_id" {
      type = varchar(50)
      null = NOT NULL
    }
    column "schedule_code" {
      type = varchar(50)
    }
    column "task_code" {
      type = varchar(50)
    }
    column "state" {
      type = enum('SUCCESSFUL','FAILURE')
    }
    column "last_executed_on" {
      type = datetime
    }
    column "action" {
      type = enum('CREATED','STARTED','EXECUTED','COMPLETED','ERROR','PAUSED','STOPPED','DELETED')
    }
    column "tenant_id" {
      type = varchar(50)
    }
    column "created_on" {
      type = datetime
    }
    column "created_by" {
      type = varchar(50)
    }
    column "modified_by" {
      type = varchar(50)
    }
    column "modified_on" {
      type = datetime
    }
  )
  primaryKey = {
    columns = [
      txn_id
    ]
    name = "PRIMARY"
    objectType = primaryKey
  }
}

foreignKey "flyway_desktop"."chs_core_job_schedule_txns"."fk_job_txn_schedule" {
  columns = [
    "schedule_code"
  ]
  referencedTable = "flyway_desktop"."chs_core_job_schedule_master"
  referencedColumns = [
    "schedule_code"
  ]
}

