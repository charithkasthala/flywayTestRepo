foreignKey "flyway_desktop"."chs_core_job_schedule_txns"."fk_schedule_txn_task" {
  columns = [
    "task_code"
  ]
  referencedTable = "flyway_desktop"."chs_core_job_task_master"
  referencedColumns = [
    "task_code"
  ]
}

