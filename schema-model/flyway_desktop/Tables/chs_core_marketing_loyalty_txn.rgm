    }

    {
      name = reference_id
    }

  >
  type = BTREE
}

index "flyway_desktop"."chs_core_marketing_loyalty_txn"."idx_txn_type" {
  columns = <
    {
      name = txn_type
    }

  >
  type = BTREE
}

index "flyway_desktop"."chs_core_marketing_loyalty_txn"."loyalty_account_id" {
  columns = <
    {
