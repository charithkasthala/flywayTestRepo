    }
    column "length" {
      type = decimal(10,2)
    }
    column "width" {
      type = decimal(10,2)
    }
    column "height" {
      type = decimal(10,2)
    }
    column "weight" {
      type = decimal(10,2)
    }
    column "created_on" {
      type = datetime
    }
    column "created_by" {
      type = varchar(50)
    }
    column "modified_on" {
      type = datetime
    }
    column "modified_by" {
      type = varchar(50)
    }
  )
  primaryKey = {
    columns = [
      id
    ]
    name = "PRIMARY"
    objectType = primaryKey
  }
}

