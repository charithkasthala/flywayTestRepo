table "flyway_desktop"."qrtz_locks" {
  columns = (
    column "SCHED_NAME" {
      type = varchar(120)
      null = NOT NULL
    }
    column "LOCK_NAME" {
      type = varchar(40)
      null = NOT NULL
    }
  )
  primaryKey = {
    columns = [
      SCHED_NAME
      LOCK_NAME
    ]
