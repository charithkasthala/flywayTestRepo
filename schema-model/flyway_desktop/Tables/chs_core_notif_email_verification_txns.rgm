table "flyway_desktop"."chs_core_notif_email_verification_txns" {
  columns = (
    column "id" {
      type = varchar(50)
      null = NOT NULL
    }
    column "email_id" {
      type = varchar(250)
    }
    column "token" {
      type = varchar(500)
    }
    column "is_verified" {
      type = tinyint
    }
    column "tenant_id" {
      type = varchar(50)
    }
  )
  primaryKey = {
    columns = [
      id
    ]
    name = "PRIMARY"
    objectType = primaryKey
  }
}

